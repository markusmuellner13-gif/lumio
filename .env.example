# Lumio environment variables
# Locally: copy this file to ".env.local" and fill in the values.
# On Vercel: add these as Project Environment Variables.

# Required for chat. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enables accounts, cloud sync, and shareable links.
# These are public values, protected by Supabase Row Level Security.
# Leave them empty to run Lumio in local-only mode (history saved in the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
